APP_HOST=0.0.0.0
APP_PORT=3000

# Pick one:
# DATABASE_URL=sqlite://./zhiying.db?mode=rwc
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/zhiying
# DATABASE_URL=mysql://root:password@127.0.0.1:3306/zhiying
DATABASE_URL=sqlite://./zhiying.db?mode=rwc

JWT_SECRET=change-me-in-production
JWT_TTL_DAYS=30
CORS_ALLOW_ORIGIN=*
CHECKIN_REWARD_SEQUENCE=1,2,3,4,6,8,10
CHECKIN_MAKEUP_GOLD_COST_PER_DAY=50
CHECKIN_MAKEUP_DIAMOND_COST=1

# Content generation costs
KNOWLEDGE_VIDEO_DIAMOND_COST=5
CODE_VIDEO_DIAMOND_COST=5
INTERACTIVE_HTML_GOLD_COST=10
KNOWLEDGE_EXPLANATION_GOLD_COST=10

# Microservice URLs
KNOWLEDGE_VIDEO_SERVICE_URL=http://localhost:8001
CODE_VIDEO_SERVICE_URL=http://localhost:8002
INTERACTIVE_HTML_SERVICE_URL=http://localhost:8003
KNOWLEDGE_EXPLANATION_SERVICE_URL=http://localhost:8004

# Microservice API keys (must start with sk-)
KNOWLEDGE_VIDEO_API_KEY=sk-knowledge-video-dev
CODE_VIDEO_API_KEY=sk-code-video-dev
INTERACTIVE_HTML_API_KEY=sk-interactive-html-dev
KNOWLEDGE_EXPLANATION_API_KEY=sk-knowledge-explanation-dev

# Study subject
STUDY_SUBJECT_DIAMOND_COST=10
PRETEST_SERVICE_URL=http://localhost:8010
PRETEST_API_KEY=sk-pretest-dev
PLAN_SERVICE_URL=http://localhost:8011
PLAN_API_KEY=sk-plan-dev
QUIZ_SERVICE_URL=http://localhost:8012
QUIZ_API_KEY=sk-quiz-dev
STUDY_QUIZ_FREE_LIMIT_PER_TASK=3
STUDY_QUIZ_EXTRA_GOLD_COST=20

# Recharge
RECHARGE_API_KEY=sk-recharge-dev
