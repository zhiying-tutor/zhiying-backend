APP_HOST=0.0.0.0
APP_PORT=9000

# Pick one:
# DATABASE_URL=sqlite://zhiying-backend.db?mode=rwc
# DATABASE_URL=postgres://dev:dev@127.0.0.1:5432/zhiying_backend
# DATABASE_URL=mysql://dev:dev@127.0.0.1:3306/zhiying_backend
DATABASE_URL=sqlite://zhiying-backend.db?mode=rwc

JWT_SECRET=change-me-in-production
JWT_TTL_DAYS=30
CORS_ALLOW_ORIGIN=*
REGISTER_BONUS_DIAMONDS=80
CHECKIN_REWARD_SEQUENCE=1,2,3,4,6,8,10
CHECKIN_MAKEUP_GOLD_COST_PER_DAY=50
CHECKIN_MAKEUP_DIAMOND_COST=1

# Content generation costs
KNOWLEDGE_VIDEO_DIAMOND_COST=5
CODE_VIDEO_DIAMOND_COST=5
INTERACTIVE_HTML_GOLD_COST=10
KNOWLEDGE_EXPLANATION_GOLD_COST=10

# RabbitMQ (microservice dispatch goes through here; callbacks remain HTTP)
RABBITMQ_URL=amqp://dev:dev@localhost:5672/%2f

# Microservice exchanges (RabbitMQ direct exchanges, queue zhiying.<svc>.generate, routing key "generate")
KNOWLEDGE_VIDEO_EXCHANGE=zhiying.knowledge_video
CODE_VIDEO_EXCHANGE=zhiying.code_video
INTERACTIVE_HTML_EXCHANGE=zhiying.interactive_html
KNOWLEDGE_EXPLANATION_EXCHANGE=zhiying.knowledge_explanation

# Microservice API keys (must start with sk-, used by callbacks back to this server)
KNOWLEDGE_VIDEO_API_KEY=sk-knowledge-video-dev
CODE_VIDEO_API_KEY=sk-code-video-dev
INTERACTIVE_HTML_API_KEY=sk-interactive-html-dev
KNOWLEDGE_EXPLANATION_API_KEY=sk-knowledge-explanation-dev

# Study subject
# key = total_stages, value = diamond cost; entries separated by ',', key:value separated by ':'
STUDY_SUBJECT_DIAMOND_COSTS=3:10,7:20,15:40,30:80
PRETEST_EXCHANGE=zhiying.pretest
PRETEST_API_KEY=sk-pretest-dev
PLAN_EXCHANGE=zhiying.plan
PLAN_API_KEY=sk-plan-dev
QUIZ_EXCHANGE=zhiying.quiz
QUIZ_API_KEY=sk-quiz-dev
STUDY_QUIZ_FREE_LIMIT_PER_TASK=3
STUDY_QUIZ_EXTRA_GOLD_COST=20

# Recharge
RECHARGE_API_KEY=sk-recharge-dev
